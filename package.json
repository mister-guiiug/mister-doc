{
  "name": "mister-doc",
  "private": true,
  "license": "MIT",
  "version": "1.0.0",
  "type": "module",
  "description": "mister-doc — PWA de synchronisation du planning de gardes des médecins d'un hôpital. Vue mensuelle des créneaux, authentification Supabase, compteurs week-end et heures par médecin.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --base /mister-doc/",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npm --prefix e2e test",
    "type-check": "tsc -b",
    "icons": "node scripts/generate-pwa-icons.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "lucide-react": "^1.17.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "eslint": "^9.18.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^16.0.0",
    "jsdom": "^26.0.0",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.3.0",
    "typescript": "~5.9.0",
    "typescript-eslint": "^8.20.0",
    "vite": "^8.0.0",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^4.0.0"
  }
}
